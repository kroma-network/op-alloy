{"doc_urls":["intro.html#op-alloy-book","intro.html#introduction","intro.html#development-status","intro.html#contributing","glossary.html#glossary","CONTRIBUTING.html#contributing","CONTRIBUTING.html#dependencies","CONTRIBUTING.html#pull-request-process"],"index":{"documentStore":{"docInfo":{"0":{"body":28,"breadcrumbs":4,"title":3},"1":{"body":36,"breadcrumbs":2,"title":1},"2":{"body":8,"breadcrumbs":3,"title":2},"3":{"body":8,"breadcrumbs":2,"title":1},"4":{"body":9,"breadcrumbs":2,"title":1},"5":{"body":16,"breadcrumbs":2,"title":1},"6":{"body":27,"breadcrumbs":2,"title":1},"7":{"body":63,"breadcrumbs":4,"title":3}},"docs":{"0":{"body":"Documentation for op-alloy. 📖 op-alloy is in active development, and is not yet ready for use in production. During development, this book will evolve quickly and may contain inaccuracies. Please open an issue if you find any errors or have any suggestions for improvements, and also feel free to contribute to the project!","breadcrumbs":"Introduction » op-alloy Book","id":"0","title":"op-alloy Book"},"1":{"body":"op-alloy is a collection of types, middleware, and networks for Optimism built on top of alloy . It is built and maintained by Alloy contributors, members of OP Labs , and the broader open source community. op-alloy is licensed under the combined Apache 2.0 and MIT License, along with a SNAPPY license for snappy encoding use.","breadcrumbs":"Introduction » Introduction","id":"1","title":"Introduction"},"2":{"body":"op-alloy is currently in active development, and is not yet ready for use in production.","breadcrumbs":"Introduction » Development Status","id":"2","title":"Development Status"},"3":{"body":"Contributors are welcome! Please see the contributing guide for more information.","breadcrumbs":"Introduction » Contributing","id":"3","title":"Contributing"},"4":{"body":"This document contains definitions for terms used throughout the op-alloy book.","breadcrumbs":"Glossary » Glossary","id":"4","title":"Glossary"},"5":